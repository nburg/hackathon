{
  "name": "wxt-starter",
  "description": "manifest.json description",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "npx wxt prepare",
    "lint": "eslint src/**/*.{ts,tsx} lib/**/*.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@types/chrome": "^0.1.38",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.6",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^20.8.4",
    "postcss": "^8.5.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wxt": "^0.20.20"
  }
}
